<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Library Management System</title>

    <link rel="stylesheet" href="/css/home.css">

    <!-- Font Awesome Icons -->
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

    <!-- Navbar -->
    <nav>
        <div class="logo">
            <i class="fas fa-book-open"></i>
            LMS
        </div>

        <ul>
            <li><a href="/books">Books</a></li>
            <li><a href="/login">Login</a></li>
            <li><a href="/register">Register</a></li>
        </ul>
    </nav>

    <!-- Hero Section -->
    <section class="hero">

        <div class="hero-content">
            <h1>
                <i class="fas fa-book-reader"></i>
                Library Management System
            </h1>

            <p>
                Manage books, track borrowing records, and maintain your
                library efficiently with our modern LMS.
            </p>

            <div class="buttons">
                <a href="/books" class="btn primary">
                    <i class="fas fa-book"></i>
                    View Books
                </a>

                <a href="/register" class="btn secondary">
                    Get Started
                </a>

                <a href="/login" class="btn secondary">
                    Login
                </a>
            </div>
        </div>

        <div class="hero-image">
            <img
            src="https://images.unsplash.com/photo-1521587760476-6c12a4b040da?w=800"
            alt="Library">
        </div>

    </section>

    <!-- Features -->
    <section class="features">

        <div class="card">
            <i class="fas fa-book"></i>
            <h3>Books</h3>
            <p>Manage all library books easily.</p>
        </div>

        <div class="card">
            <i class="fas fa-users"></i>
            <h3>Members</h3>
            <p>Track registered library users.</p>
        </div>

        <div class="card">
            <i class="fas fa-exchange-alt"></i>
            <h3>Borrow Records</h3>
            <p>Monitor issue and return records.</p>
        </div>

    </section>

</body>
</html>